    "@dcloudio/uni-app": "3.0.0-alpha-5000320260310001",
    "@dcloudio/uni-app-plus": "3.0.0-alpha-5000320260310001",
    "@dcloudio/uni-components": "3.0.0-alpha-5000320260310001",

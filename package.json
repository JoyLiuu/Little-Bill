    "@dcloudio/uni-mp-kuaishou": "3.0.0-alpha-5000320260310001",
    "@dcloudio/uni-mp-lark": "3.0.0-alpha-5000320260310001",
    "@dcloudio/uni-mp-qq": "3.0.0-alpha-5000320260310001",
    "@dcloudio/uni-mp-toutiao": "3.0.0-alpha-5000320260310001",
    "@dcloudio/uni-mp-weixin": "3.0.0-alpha-5000320260310001",
    "@dcloudio/uni-quickapp-webview": "3.0.0-alpha-5000320260310001",
    "clipboard": "^2.0.11",
    "dayjs": "^1.11.11",
    "pinia": "^2.1.7",

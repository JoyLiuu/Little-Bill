  },
  "devDependencies": {
    "@dcloudio/types": "^3.4.8",
    "@dcloudio/uni-automator": "3.0.0-alpha-5000320260310001",
    "@dcloudio/uni-cli-shared": "3.0.0-alpha-5000320260310001",
    "@dcloudio/uni-stacktracey": "3.0.0-alpha-5000320260310001",

{
  "easycom": {
    "autoscan": true,
    "custom": {
      "^u--(.*)": "uview-plus/components/u-$1/u-$1.vue",
      "^up-(.*)": "uview-plus/components/u-$1/u-$1.vue",
      "^u-([^-].*)": "uview-plus/components/u-$1/u-$1.vue"
    }
  },
  "pages": [
    {
      "path": "pages/index/index",
      "style": {
        "navigationBarTitleText": "首页"
      }
    },
    {
      "path": "pages/ledger/ledger",
      "style": {
        "navigationBarTitleText": "记账本"
      }
    },
    {
      "path": "pages/statistics/statistics",
      "style": {
        "navigationBarTitleText": "统计"
      }
    },
    {
      "path": "pages/funds/funds",
      "style": {
        "navigationBarTitleText": "资金池"
      }
    },
    {
      "path": "pages/profile/profile",
      "style": {
        "navigationBarTitleText": "我的"
      }
    },
    {
      "path": "pages/annual-report/annual-report",
      "style": {
        "navigationBarTitleText": "年度报告"
      }
    }
  ],
  "globalStyle": {
    "navigationBarTextStyle": "black",
    "navigationBarTitleText": "记账小程序",
    "navigationBarBackgroundColor": "#F8F8F8",
    "backgroundColor": "#F8F8F8"
  },
  "tabBar": {
    "color": "#7AADCC",
    "selectedColor": "#3E8FD4",
    "borderStyle": "black",
    "backgroundColor": "#ffffff",
    "list": [
      {
        "pagePath": "pages/index/index",
        "text": "首页",
        "iconPath": "static/tabbar/home.svg",
        "selectedIconPath": "static/tabbar/home-active.svg"
      },
      {
        "pagePath": "pages/ledger/ledger",
        "text": "记账",
        "iconPath": "static/tabbar/ledger.svg",
        "selectedIconPath": "static/tabbar/ledger-active.svg"
      },
      {
        "pagePath": "pages/statistics/statistics",
        "text": "统计",
        "iconPath": "static/tabbar/chart.svg",
        "selectedIconPath": "static/tabbar/chart-active.svg"
      },
      {
        "pagePath": "pages/funds/funds",
        "text": "资金",
        "iconPath": "static/tabbar/funds.svg",
        "selectedIconPath": "static/tabbar/funds-active.svg"
      },
      {
        "pagePath": "pages/profile/profile",
        "text": "我的",
        "iconPath": "static/tabbar/profile.svg",
        "selectedIconPath": "static/tabbar/profile-active.svg"
      }
    ]
  },
  "uniIdRouter": {}
}
